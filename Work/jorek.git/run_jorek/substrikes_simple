#!/usr/bin/env bash

# -----------------------------------------------------------------
# script used to submit the jorek job
# -----------------------------------------------------------------
if [ $# -lt 6 ]; then
   echo "==================================================================================="
   echo " Syntaxe subjorek model_number n_tor n_period n_plane restart_file namelist_file"
   echo "       Example:  subjorek 303 1 1 4 inlowshape.h5 inlowshape"
   echo "==================================================================================="
   echo " "
   exit
fi

# storing the inputs
# ------------------
MODELNUMBER=$1
NTOR=$2
NPERIOD=$3
NPLANE=$4
DATANAME=$5
NMLNAME=$6
echo "==================================================================================="
echo " execution of model '"$MODELNUMBER"' with data file '"$DATANAME"', namelist file '"$NMLNAME"', compiled with "
echo " parameters 'n_tor = "$NTOR"', 'n_period = "$NPERIOD"', 'n_plane = "$NPLANE"'"
echo "==================================================================================="
echo " "

# case name
# ---------
BASEDATANAME=`basename $DATANAME .h5`
CASENAME=`echo $BASEDATANAME | tr '[:lower:]' '[:upper:]'`
MACHNAME=`echo $ARCH | tr '[:lower:]' '[:upper:]'`

FIRSTCAR=${MACHNAME:0:1}
LASTCAR_MODEL=${MODELNUMBER}
CASE=D${FIRSTCAR}_${LASTCAR_MODEL}_${CASENAME}

if [ -f go_$BASEDATANAME.cmd ]; then
   rm -f go_$BASEDATANAME.cmd
fi

# According to ARCH variable
# --------------------------
case ${ARCH} in

# -----------------------------------------------------------------
# norma (IRFM)
# -----------------------------------------------------------------
nfs*)

# batch control
# -------------
MPIPROCS=1
NTHREAD=8
NNODES=2
WALLTIME=02:00:00
((NPES=NNODES*MPIPROCS))
echo "==================================================================================="
echo " ${NNODES} nodes with ${MPIPROCS} process MPI per node and ${NTHREAD} threads per MPI process "
echo " NPES = $NNODES x $MPIPROCS = " $NPES
echo "==================================================================================="
echo " "

# Environment
# -----------
DIR=$(dirname $PWD)
SRCDIR=${SRCDIR:-$DIR}
WKDIR=`pwd`
UTILDIR=${SRCDIR}/util

DIR=${RESPREFIX:-$(basename $(dirname $PWD))}
RESDIR1=/data/${USER}/${DIR}
RESDIR=${RESDIR1}/${CASE}

# Creation of the work directory
# ------------------------------
if [ ! -d ${RESDIR1} ]; then
   mkdir -p ${RESDIR1}
fi

if [ ! -d ${RESDIR} ]; then
   mkdir -p ${RESDIR}
   ln -s ${RESDIR} ${CASE}
fi

source /data/JOREK/jorek_env/jorek_env.sh
;;

# -----------------------------------------------------------------
# ccamu (Marseille)
# -----------------------------------------------------------------
ccamu*)

# batch control
# -------------
MPIPROCS=12
NTHREAD=1
NNODES=16
#NTHREAD=1
#NNODES=1
WALLTIME=00:29:00
((NLIM=MPIPROCS*NTHREAD))
if [ "${NLIM}" -gt "13" ]; then
   echo "${NLIM} = ", ${NLIM}
   echo " MPIPROCS*NTHREAD is greater than 12, you are trying to run more MPI processes and threads than reasonable"
   echo " ===> try running MPIPROCS=1 (1 MPI process per node) and NTHREAD=12 ...."
   exit
fi
((NPES=NNODES*MPIPROCS))
echo "==================================================================================="
echo " ${NNODES} nodes with ${MPIPROCS} process MPI per node and ${NTHREAD} threads per MPI process "
echo " NPES = $NNODES x $MPIPROCS = " $NPES
echo "==================================================================================="
echo " "

# Environment
# -----------
DIR=$(dirname $PWD)
SRCDIR=${SRCDIR:-$DIR}
WKDIR=`pwd`
UTILDIR=${SRCDIR}/util

DIR=${RESPREFIX:-$(basename $(dirname $PWD))}
RESDIR1=/scratch/${USER}/${DIR}
RESDIR1=${RESDIR1%/}
