# batch control
# -------------
MPIPROCS=1
NTHREAD=8
NNODES=16
WALLTIME=1800
((NPES=NNODES*MPIPROCS))
echo "==================================================================================="
echo " ${NNODES} nodes with ${MPIPROCS} process MPI per node and ${NTHREAD} threads per MPI process "
echo " NPES = $NNODES x $MPIPROCS = " $NPES
echo "==================================================================================="
echo " "

# Environment
# -----------
DIR=$(basename $(dirname $PWD))
HOMEDIR=/scratch/$USER/${DIR}
SRCDIR=$HOMEDIR
UTILDIR=${SRCDIR}/util

DIR=$(basename $PWD)
WKDIR=${HOMEDIR}/${DIR}
RESDIR1=${WKDIR}
RESDIR=${RESDIR1}/${CASE}

# Creation of the work directory
# ------------------------------
if [ ! -d ${RESDIR} ]; then
   mkdir -p ${RESDIR}
fi
;;

