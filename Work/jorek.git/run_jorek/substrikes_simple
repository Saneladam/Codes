# hpc-ff (Juelich)
# -----------------------------------------------------------------
hpcff*)

# batch control
# -------------
NODES=32
NTHREAD=8
PPN=8   # processs per node=8: reserve the whole node
WALLTIME=02:00:00
((NSLOTS=NODES * PPN / NTHREAD))
echo "==================================================================================="
echo " ${NODES} nodes are asked for, with ${PPN} processes per node (the whole node) and ${NTHREAD} threads "
echo "==================================================================================="
echo " "

# Environment
# -----------
DIR=$(dirname $PWD)
SRCDIR=$DIR
WKDIR=`pwd`
UTILDIR=${SRCDIR}/util
RESDIR1=`echo $HOME | sed "s/jhome*[0123456789]/jwork/" `

# Creation of the work directory
# ------------------------------
RESDIR=${RESDIR1}/${CASE}
if [ ! -d ${RESDIR} ]; then
   mkdir -p ${RESDIR}
   ln -s ${RESDIR} ${CASE}
fi
;;

