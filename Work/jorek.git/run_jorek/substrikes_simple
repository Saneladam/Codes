   echo "SRCDIR = " ${SRCDIR}
   echo "STRIKEXECNAME = "  ${STRIKEXECNAME}
   echo " Executable ${STRIKEXECNAME} does not exist, so exit ";
   exit
else
    cp ${SRCDIR}/${STRIKEXECNAME} ${RESDIR}/.
fi

if [ ! -e ${WKDIR}/${DATANAME} ]; then
    echo " Datafile ${DATANAME} does no exist, so exit ";
    exit
else
    cp ${WKDIR}/${DATANAME} ${RESDIR}/jorek_restart.h5
fi

if [ ! -e ${WKDIR}/${NMLNAME} ]; then
    echo " namelist file ${NMLNAME} does no exist, so exit ";
    exit
else
    cp ${WKDIR}/${NMLNAME} ${RESDIR}/${NMLNAME}
