# echo " DIR " $DIR
DIR2=$(dirname $DIR)
# echo " DIR2 " $DIR2
DIR3=$(basename $DIR2)
# echo " DIR3 " $DIR3
HOMEDIR2=$WORKDIR/${DIR}
HOMEDIR=${DIR}
SRCDIR=$HOMEDIR
UTILDIR=${HOMEDIR}/util
WKDIR=`pwd`

RESDIR1=$SCRATCHDIR/${DIR3}
RESDIR=${RESDIR1}/${CASE}
