# Creation of the work directory
# ------------------------------
if [ ! -d ${RESDIR1} ]; then
   mkdir -p ${RESDIR1}
fi

if [ ! -d ${RESDIR} ]; then
   mkdir -p ${RESDIR}
   ln -s ${RESDIR} ${CASE}
fi

# Creation of the work directory
# ------------------------------
if [ ! -d ${RESDIR} ]; then
   mkdir -p ${RESDIR}
fi

;;

