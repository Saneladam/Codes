# Configuration file for JOREK on HYDRA
#
# Load modules: intel, fftw, mkl, mpi.intel
#

# model directory
MODEL = model199

# Fortran compiler 
FC               = mpiifort -mt_mpi
CC               = mpiicc   -mt_mpi
CXX              = mpiicpc  -mt_mpi
FLAGS_OMP        = -openmp 
FFLAGS           = -r8 -i4
FFLAGS          := $(FFLAGS) -fpp
FFLAGS          := $(FFLAGS) -traceback -xSSSE3 -align
FFLAGS          := $(FFLAGS) -O2

# --- DEBUGGING
#   --- Debug symbols for debuggers
DEBUGFLAGS  = -g # -p
#   --- Check array boundaries
#DEBUGFLAGS += -check bounds
#   --- Generate and check interfaces (__genmod files)
#DEBUGFLAGS += -gen-interfaces -warn interfaces
#   --- Check many other things
#DEBUGFLAGS += -warn all,nounused -check all,noarg_temp_created -debug all -debug-parameters -fstack-security-check
#   --- Even more checks and warnings
#DEBUGFLAGS += -warn all -check all -ftrapuv

FFLAGS_FIXEDFORM := $(FFLAGS) $(DEBUGFLAGS) $(FFLAGS_OMP)
FFLAGS_NOBOUNDS  := $(FFLAGS)               $(FFLAGS_OMP)
FFLAGS           := $(FFLAGS) $(DEBUGFLAGS) $(FFLAGS_OMP)

FFLAGS_NO_OMP    = $(FFLAGS) $(DEBUGFLAGS)

# Solvers dependencies
USE_HIPS   = 0
USE_PASTIX = 1
USE_PASTIX_MURGE = 1
USE_MUMPS  = 0
USE_WSMP   = 0

#Library directory
LIB_DIR = /afs/ipp/u/mhoelzl/mylib/amd64_sles11/

#Scotch library
SCOTCH_HOME ?= $(HOME)/scotch_5.1.11
LIB_SCOTCH   = -L$(SCOTCH_HOME)/lib -lscotch -lscotcherr
INC_SCOTCH   = -I$(SCOTCH_HOME)/include

# MUMPS
MUMPS_HOME = $(LIB_DIR)/MUMPS_4.9.2
LIB_MUMPS  = -L$(MUMPS_HOME)/lib/ -ldmumps -lmumps_common
LIB_ZMUMPS = $(MUMPS_HOME)/lib/libzmumps.a
INC_MUMPS  = $(MUMPS_HOME)/include/
ORDLIB     = $(MUMPS_HOME)/lib/libpord.a #$(LIBDIR)/metis-4.0/libmetis.a

# PASTIX
PASTIX_HOME     ?= $(LIB_DIR)/pastix_release_4030_gotoblas/install
LIB_PASTIX       = `$(PASTIX_HOME)/pastix-conf --libs` 
LIB_PASTIX_MURGE = `$(PASTIX_HOME)/pastix-conf --libs_murge`
LIB_PASTIX_BLAS  = `$(PASTIX_HOME)/pastix-conf --blas`
INC_PASTIX       = `$(PASTIX_HOME)/pastix-conf --incs`

#HIPS
#LIBHIPS   = -L$(HOME)/hips_trunk/trunk/LIB -lhips -lio $(LIBSCOTCH)
#INCHIPS   = -I$(HOME)/hips_trunk/trunk/LIB

#WSMP
LIB_WSMP = -L$(WSMP_HOME)/intelmpi -lpwsmp64

# LIBFFTW
LIBFFTW   = $(FFTW_HOME)/lib/libfftw3.a
#LIBFFTW   = -L/opt/cluster/fftw/3.2.2/intel-11.1-069/intel-4.0.0.025 -lfftw3

# MKL 10.3: Generated by Intel MKL Link Advisor: 
SCALAP = $(MKL_HOME)/lib/intel64/libmkl_scalapack_lp64.a  -Wl,--start-group                         \
  $(MKL_HOME)/lib/intel64/libmkl_intel_lp64.a $(MKL_HOME)/lib/intel64/libmkl_intel_thread.a         \
  $(MKL_HOME)/lib/intel64/libmkl_core.a $(MKL_HOME)/lib/intel64/libmkl_blacs_intelmpi_lp64.a        \
  -Wl,--end-group -openmp -lpthread

# MKL 10.1
#SCALAP = $(MKL_HOME)/lib/$(dir64)/libmkl_scalapack_lp64.a $(MKL_HOME)/lib/$(dir64)/libmkl_blacs_intelmpi_lp64.a
#LIBLAPACK = -L$(MKL_HOME)/lib/$(dir64) -mkl=parallel

