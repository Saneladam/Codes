#!/bin/bash
#PBS -N _CASE_
#PBS -q xfuasklprod
#PBS -A _PROJ_
#PBS -l select=1:ncpus=48:mpiprocs=2
#PBS -l place=excl
#PBS -j oe
#PBS -V
#PBS -l walltime=0:15:00
#PBS -m e

########################################################################
# Look to non_regression_tests/testcases/_CASE_/settings.sh
# to determine nb of nodes, MPI processes, and nb of threads
########################################################################

# git is needed by default.mk, and not available by default on Marconi nodes
module load git

cd $PBS_O_WORKDIR

ulimit -l unlimited
ulimit -s unlimited

CASE=_CASE_
JOREK_HOME=`readlink -f ${PWD}/../../..` # Assumption about source code location
echo " jorek_home = " ${JOREK_HOME}

export OMP_NUM_THREADS=24

#export NPROC=`qstat -f $PBS_JOBID | awk '/Resource_List.mpiprocs/ {print $3}'`

cd ${JOREK_HOME}
source non_regression_tests/job_scripts/marconi_skl/env.sh
echo $MPIRUN
## Compile with:       
#non_regression_tests/run_test.sh -p $CASE
## Initial Long run: 
#non_regression_tests/run_test.sh -i -k -n $CASE 
## Restart run: 
non_regression_tests/run_test.sh -k -n $CASE 

